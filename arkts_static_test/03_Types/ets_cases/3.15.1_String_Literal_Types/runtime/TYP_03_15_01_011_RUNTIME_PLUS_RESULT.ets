/**
 * @id TYP_03_15_01_011_RUNTIME_PLUS_RESULT
 * @expect runtime
 * @section 3.15.1
 * @design 验证 string literal type + 运算结果为 string 类型
 * @note 运行时用例：实际执行验证运算结果
 */
function main(): void {
  let s0: "string literal" = "string literal"
  let s1: string = s0 + s0

  if (s1 !== "string literalstring literal") throw new Error("s1 assert failed")

  // 验证结果类型是 string，不是 string literal
  let s2: string = s1  // OK，因为 s1 是 string 类型
  if (s2 !== s1) throw new Error("s2 assert failed")

  console.log("verified")
}
